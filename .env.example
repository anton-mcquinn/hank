# Copy to backend/.env and fill in real values.
# Backend boot will refuse to start if any required value is missing or weak.
# R2 vars are all-or-nothing: set every one, or none (local-disk fallback).

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Security — generate a strong secret with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hank

# CORS — comma-separated list of allowed origins for your frontend
# In production, set this to your Expo/app URL or deployed frontend domain
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://localhost:19006

# --- Cloudflare R2 -----------------------------------------------------------
# Account ID: R2 dashboard home page.
# Access keys: "Manage R2 API Tokens" in the R2 dashboard.
# Bucket names: whatever you created (private + public access policies).
# Public base URL: the public bucket's r2.dev address or your custom domain.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PRIVATE=hank-private
R2_BUCKET_PUBLIC=hank-public
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# --- Optional ----------------------------------------------------------------

# Local-disk storage fallback (only used when the R2 vars above are unset).
# LOCAL_STORAGE_DIR=./local_storage

# Shop-info fallbacks used on invoices/estimates when shop_settings is empty.
# COMPANY_NAME=Auto Shop
# COMPANY_ADDRESS=123 Main St, Anytown, USA
# COMPANY_PHONE=(555) 123-4567
# COMPANY_EMAIL=service@autoshop.com
# COMPANY_WEBSITE=www.yourautoshop.com
