# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Security — generate a strong secret with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hank

# File storage — use absolute paths in production (e.g. /var/www/hank/uploads)
UPLOAD_DIR=./uploads
INVOICE_DIR=./invoices

# CORS — comma-separated list of allowed origins for your frontend
# In production, set this to your Expo/app URL or deployed frontend domain
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://localhost:19006
